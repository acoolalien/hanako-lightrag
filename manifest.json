{
  "manifestVersion": 1,
  "id": "hanako-lightrag",
  "name": "LightRAG 知识库",
  "version": "0.1.0",
  "description": "基于 LightRAG 的知识图谱 RAG 引擎。支持文档索引、语义检索、知识图谱可视化和多模式查询（local/global/hybrid/mix/naive）。",
  "minAppVersion": "0.140.0",
  "trust": "full-access",
  "activationEvents": ["onStartup"],
  "ui": {
    "hostCapabilities": ["external.open"]
  },
  "contributes": {
    "page": {
      "title": { "zh": "图谱", "en": "LightRAG" },
      "route": "/page",
      "icon": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><circle cx='12' cy='12' r='3'/><circle cx='5' cy='6' r='2'/><circle cx='19' cy='6' r='2'/><circle cx='5' cy='18' r='2'/><circle cx='19' cy='18' r='2'/><line x1='8' y1='7.5' x2='10' y2='10.5'/><line x1='16' y1='7.5' x2='14' y2='10.5'/><line x1='8' y1='16.5' x2='10' y2='13.5'/><line x1='16' y1='16.5' x2='14' y2='13.5'/></svg>"
    },
    "configuration": {
      "properties": {
        "llmProviderId": {
          "type": "string",
          "default": "deepseek",
          "title": "LLM Provider ID",
          "description": "Hanako 中配置的 LLM Provider 的 ID，用于实体提取和查询生成。"
        },
        "embeddingProviderId": {
          "type": "string",
          "default": "siliconflow",
          "title": "Embedding Provider ID",
          "description": "Hanako 中配置的 Embedding Provider 的 ID，用于向量嵌入。"
        },
        "embedModel": {
          "type": "string",
          "default": "Qwen/Qwen3-Embedding-8B",
          "title": "嵌入模型",
          "description": "嵌入模型名称。切换模型需清空向量库重新索引。"
        },
        "embedDim": {
          "type": "number",
          "default": 4096,
          "title": "嵌入维度",
          "description": "嵌入向量的维度，需与模型匹配。切换需重新索引。"
        },
        "rerankEnabled": {
          "type": "boolean",
          "default": false,
          "title": "启用重排",
          "description": "是否在 mix 模式下启用 Reranker 对检索结果重排。需配置 rerankProviderId。"
        },
        "rerankProviderId": {
          "type": "string",
          "default": "",
          "title": "Rerank Provider ID",
          "description": "Reranker 的 Provider ID。留空则不启用重排。"
        },
        "lightragPort": {
          "type": "number",
          "default": 9621,
          "title": "LightRAG 服务端口",
          "description": "LightRAG FastAPI server 的监听端口。"
        },
        "workingDir": {
          "type": "string",
          "default": "",
          "title": "数据存储目录",
          "description": "LightRAG 索引和缓存的存储路径。留空则使用插件数据目录。"
        },
        "defaultQueryMode": {
          "type": "string",
          "enum": ["local", "global", "hybrid", "mix", "naive", "bypass"],
          "default": "mix",
          "title": "默认查询模式"
        },
        "entityTypes": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["PERSON", "ORGANIZATION", "LOCATION", "EVENT", "CONCEPT", "ITEM", "ABILITY", "RELATIONSHIP", "TIME_PERIOD", "LAW_RULE"],
          "title": "实体类型",
          "description": "LightRAG 实体提取时使用的实体类型列表。"
        },
        "summaryLanguage": {
          "type": "string",
          "enum": ["Chinese", "English", "Japanese", "auto"],
          "default": "Chinese",
          "title": "摘要语言"
        },
        "maxGleaning": {
          "type": "number",
          "default": 0,
          "title": "最大 Gleaning 次数",
          "description": "实体提取的额外循环次数，0=跳过以节省 token。"
        },
        "chunkSize": {
          "type": "number",
          "default": 1200,
          "title": "分块大小（tokens）"
        },
        "chunkOverlapSize": {
          "type": "number",
          "default": 100,
          "title": "分块重叠（tokens）"
        },
        "storageBackend": {
          "type": "string",
          "enum": ["json", "postgres"],
          "default": "json",
          "title": "存储后端",
          "description": "json=零依赖默认；postgres=PostgreSQL+pgvector。切换后端需重新索引。"
        },
        "pgHost": {
          "type": "string",
          "default": "localhost",
          "title": "PostgreSQL 主机",
          "description": "仅 storageBackend=postgres 时生效。"
        },
        "pgPort": {
          "type": "number",
          "default": 5432,
          "title": "PostgreSQL 端口",
          "description": "仅 storageBackend=postgres 时生效。"
        },
        "pgDatabase": {
          "type": "string",
          "default": "lightrag",
          "title": "PostgreSQL 数据库",
          "description": "需提前创建。仅 storageBackend=postgres 时生效。"
        },
        "pgUser": {
          "type": "string",
          "default": "postgres",
          "title": "PostgreSQL 用户名",
          "description": "仅 storageBackend=postgres 时生效。"
        },
        "pgPassword": {
          "type": "string",
          "default": "",
          "title": "PostgreSQL 密码",
          "description": "仅 storageBackend=postgres 时生效。"
        },
        "workspaces": {
          "type": "object",
          "default": { "default": "默认知识库" },
          "title": "知识库列表",
          "description": "{ \"workspace名\": \"显示名称\" }。key 用于 API 调用，value 是显示名。"
        }
      }
    }
  }
}
